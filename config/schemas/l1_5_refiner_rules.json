{
  "regex_rules": {
    "species": {
      "MACAQUE": "\\b(macaque|macaques|rhesus|cynomolgus|non-human primate)\\b",
      "ZEBRAFISH": "\\b(zebrafish|danio rerio)\\b",
      "MOUSE": "\\b(mouse|mice|murine|c57bl/6|balb/c)\\b",
      "RAT": "\\b(rat|rats|sprague-dawley|wistar|sd rat)\\b",
      "HUMAN": "\\b(human|humans|patient|patients|volunteer|healthy control|mdd subject)\\b"
    },
    "localization": {
      "PFC": "\\b(prefrontal cortex|pfc|mpfc|prefrontal cortical)\\b",
      "SUBICULUM": "\\b(subiculum|subicular)\\b",
      "CA1": "\\b(ca1|ca1 region)\\b",
      "CA3": "\\b(ca3|ca3 region)\\b",
      "DG": "\\b(dentate gyrus|dg)\\b",
      "NUCLEUS_ACCUMBENS": "\\b(nucleus accumbens|nac|acb)\\b",
      "AMYGDALA": "\\b(amygdala|basolateral amygdala|bla)\\b",
      "STRIATUM": "\\b(striatum|caudate|putamen)\\b",
      "HIPPOCAMPUS": "\\b(hippocampus|hippocampal)\\b(?!\\s*(ca1|ca3|dentate|dg|subiculum))",
      "CORTEX": "\\b(cortex|cortical|cerebral cortex)\\b(?!\\s*(prefrontal|frontal|pfc|mpfc))"
    },
    "time": {
      "30MIN": "\\b(30\\s?min|30\\s?minutes)\\b",
      "24H": "\\b(24\\s?h|24\\s?hours|1\\s?day|24-h)\\b(?!\\s*(and|to|,|across|sustained|throughout)\\s*(chronic|long-term|weeks))",
      "48H": "\\b(48\\s?h|48\\s?hours)\\b",
      "CHRONIC": "\\b(chronic|chronically|long-term|weeks|days 1-3|chronic mild stress|cms|cums)\\b"
    },
    "cell_line_or_type": {
      "HEK293": "\\b(hek293|hek\\-293|hek cells)\\b",
      "SH_SY5Y": "\\b(sh\\-sy5y|shsy5y)\\b",
      "BV2": "\\b(bv\\-2|bv2|microglial cell line)\\b",
      "PRIMARY_NEURON": "\\b(primary neuron|primary neurons|cortical neurons|cultured cells|pyramidal neuron|pyramidal neurons)\\b",
      "ASTROCYTE": "\\b(astrocyte|astrocytes|astrocytic|perisynaptic astrocytes|glial cells|glia)\\b",
      "MICROGLIA": "\\b(microglia|microglial|microglial cells|brain macrophages)\\b"
    },
    "genotype": {
      "WILD_TYPE": "\\b(wild-type|wt|control mice|control rats|littermate controls)\\b",
      "KNOCKOUT": "\\b(knockout|ko|lacking|deficient|knock-in|conditional knockout|floxoed|floxed|cre\\-driven)\\b",
      "MUTANT": "\\b(mutant|mutation|tyr\\-1325\\-phe|point mutation|transgenic|tg)\\b"
    },
    "treatment": {
      "KETAMINE": "\\b(ketamine|subanesthetic ketamine|esketamine|r\\,s\\-ketamine)\\b",
      "BDNF_INFUSION": "\\b(bdnf|bdnf infusion|brain-derived neurotrophic factor infusion)\\b",
      "TRAMADOL": "\\b(tramadol|tramadol pretreatment)\\b",
      "MEMANTINE": "\\b(memantine|high doses of memantine)\\b",
      "SCOPOLAMINE": "\\b(scopolamine)\\b"
    }
  }
}