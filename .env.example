# Copy to .env only when a command explicitly loads it. Never commit .env.

# Provider / LLM. Leave keys empty for offline work.
L1_PROVIDER=
MODEL_NAME=
OPENAI_API_KEY=<set-only-when-authorized>
DEEPSEEK_API_KEY=<set-only-when-authorized>
L1_CONNECT_TIMEOUT_SECONDS=10
L1_READ_TIMEOUT_SECONDS=240
L1_MAX_RETRIES=1
FULLTEXT_L1_V2_MAX_TOKENS=32768

# Optional L2 entity cleaner. It is inactive unless its CLI flag is enabled.
L2_ENTITY_CLEANER_PROVIDER=
L2_ENTITY_CLEANER_MODEL=

# NCBI / PubMed / PMC. NCBI_API_KEY is optional and sensitive.
NCBI_TOOL=conflict_oriented_discovery_engine
NCBI_EMAIL=
NCBI_API_KEY=<optional-ncbi-key>

# Atlas server/database. Replace the secret before authenticated use.
ATLAS_DATABASE_URL=sqlite:///data/code_atlas.db
ATLAS_SECRET_KEY=<generate-a-long-random-secret>

# Optional local validation-index build target list (comma-separated).
CODE_OMICS_TARGETS=

# Browser-test configuration only.
ATLAS_BASE_URL=http://localhost:18765
ATLAS_TRACE=0
