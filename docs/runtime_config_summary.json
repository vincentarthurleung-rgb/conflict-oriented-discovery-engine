  "recommended_concurrency": {
    "case_level_max_workers": 3,
    "l1_concurrency": 8,
    "pubmed_concurrency": 3,
    "validator_concurrency": 3,
    "case_start_stagger_seconds": 10,
    "max_retries": 2,
    "retry_backoff_seconds": 30
  },
  "current_cli": {
    "case_factory": {
      "required": ["--case-id", "--query"],
      "optional": ["--case-type", "--year-from", "--year-to", "--output-root", "--api", "--network", "--freeze-search-plan", "--run-readiness", "--copy-to-configs", "--overwrite-generated", "--overwrite-configs", "--allow-degraded-intake", "--seed-confidence-threshold", "--allow-narrow-discovery-plan", "--repository-root"]
    },
    "case_factory_batch": {
      "required": ["--seed-inventory"],
      "optional": ["--output-root", "--api", "--network", "--freeze-search-plan", "--run-readiness", "--copy-to-configs", "--overwrite-generated", "--overwrite-configs", "--allow-degraded-intake", "--allow-narrow-discovery-plan", "--repository-root"]
    },
    "run_case": {
      "required": ["--case-profile", "--search-plan-file"],
      "optional": ["--external-data-root", "--api", "--network", "--max-papers", "--temporal-role", "--l1-read-timeout-seconds", "--l1-max-retries", "--output-case-bundle-root", "--output-run-suffix", "--dry-run", "--stop-after-readiness", "--allow-warnings", "--fail-if-required-validator-unavailable", "--no-write-audit", "--enable-fulltext-confirmation", "--disable-fulltext-confirmation", "--enable-fulltext-discovery-escalation", "--disable-fulltext-discovery-escalation", "--fulltext-source", "--fulltext-max-papers", "--fulltext-include-near-conflicts", "--fulltext-max-sections-per-paper", "--fulltext-max-chunks-per-paper", "--fulltext-max-chars-per-chunk", "--fulltext-max-total-chunks", "--fulltext-l1-read-timeout-seconds", "--fulltext-l1-max-retries"]
    },
    "run_case_batch": {
      "required": ["--output-root"],
      "optional": ["--generated-case-root", "--case-ids", "--case-inventory", "--pipeline", "--external-data-root", "--api", "--network", "--database-url", "--runs-root", "--system-b-output-root", "--reuse-only", "--force-stage", "--from-stage", "--to-stage", "--stop-after", "--no-atlas-sync", "--no-publish-handoff", "--enable-fulltext-confirmation", "--max-workers", "--l1-concurrency", "--pubmed-concurrency", "--validator-concurrency", "--case-start-stagger-seconds", "--max-retries", "--retry-backoff-seconds", "--resume", "--overwrite-bundles", "--allow-degraded-intake", "--allow-narrow-discovery-plan", "--fail-fast", "--dry-run"]
    },
    "replay_case_stages": {
      "required": ["--case-id", "--case-version", "--output-bundle"],
      "optional": ["--source-run", "--source-bundle", "--from-stage", "--to-stage", "--no-llm", "--no-network", "--api", "--network", "--overwrite-bundle", "--fulltext-max-papers", "--fulltext-max-sections-per-paper", "--fulltext-max-total-chunks"]
    },
    "check_l1_provider": {
      "required": [],
      "optional": ["--scope", "--api", "--network", "--smoke-call"]
    }
  },
  "obsolete_or_unsupported_args": [
    "--input (for run_case_batch, use --generated-case-root + --case-ids instead)",
    "--api-concurrency (use --l1-concurrency instead)",
    "--retries (use --max-retries instead)",
    "--case-dir (use --generated-case-root instead)",
    "--concurrency (split into --max-workers, --l1-concurrency, --pubmed-concurrency, --validator-concurrency)",
    "--skip-readiness (not supported in run_case)",
    "--skip-fulltext (not supported in run_case)",
    "--l1-timeout (use --l1-read-timeout-seconds instead)",
    "--fulltext-l1-timeout (use --fulltext-l1-read-timeout-seconds instead)"
  ]
