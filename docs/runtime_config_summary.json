    {"name": "MODEL_NAME", "status": "SET", "used_by": ["abstract_l1", "fulltext_l1", "run_case", "readiness"], "required_for": "all L1 extraction", "safe_to_leave_empty": false, "notes": "currently 'deepseek-v4-pro'"},
    {"name": "DEEPSEEK_API_KEY", "status": "SET", "used_by": ["abstract_l1", "fulltext_l1"], "required_for": "--execute --api with deepseek provider", "safe_to_leave_empty": false, "notes": ""},
