{
  "schema_version": "context_local_chain_composition_policy_v3",
  "policy_version": "context_local_chain_composition_v3",
  "comparator_normalization_policy_version": "context_comparator_normalization_v1",
  "rules": {
    "compose_intervention_target_and_type": {
      "factor_ids": ["intervention", "treatment", "knockout_or_overexpression"],
      "components": [
        {"chain_node_id": "intervention_or_exposure", "field_path": "target_mention"},
        {"chain_node_id": "intervention_or_exposure", "field_path": "intervention_type_raw"}
      ],
      "composition_operator": "join_with_space"
    },
    "project_comparator_control_surface": {
      "factor_ids": ["comparator", "placebo_or_standard_care"],
      "components": [
        {"chain_node_id": "comparator_or_control", "field_path": "control_arm_raw"}
      ],
      "composition_operator": "identity",
      "raw_evidence_acceptance": "exact_authoritative_field_surface",
      "optional_normalized_classes": {
        "control": "control",
        "vehicle": "vehicle",
        "untreated": "untreated",
        "mock": "mock",
        "non-targeting siRNA": "non-targeting_control"
      }
    },
    "compose_experimental_design_intervention_and_comparator": {
      "factor_ids": ["experimental_design", "study_design"],
      "components": [
        {"chain_node_id": "intervention_or_exposure", "field_path": "target_mention"},
        {"chain_node_id": "intervention_or_exposure", "field_path": "intervention_type_raw"},
        {"chain_node_id": "comparator_or_control", "field_path": "control_arm_raw"}
      ],
      "composition_operator": "intervention_then_versus_comparator"
    }
  }
}
