      "critical": ["population", "diagnosis", "endpoint_definition", "study_design"]
    },
    "chemistry": {
      "display_name": "Chemistry",
      "factors": ["reactants", "reagents", "stoichiometry", "catalyst", "ligand", "additive", "solvent", "concentration", "temperature", "pressure", "atmosphere", "reaction_time", "addition_order", "workup", "purification", "yield", "selectivity", "conversion", "analytical_method"],
