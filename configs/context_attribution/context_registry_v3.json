  "factor_defaults": {
    "aliases": [],
    "value_type": "string",
    "units": [],
    "criticality": "optional",
    "applicability": "profile_defined",
    "comparison_policy": "semantic_same_equivalent_different_or_missing",
    "normalization_policy": "preserve_raw_and_propose_candidate_only",
    "controlled_normalizations": {},
    "allowed_local_inference_rules": [],
    "evidence_requirements": "one_or_more_local_anchor_ids_for_non_unknown",
    "whether_difference_can_block_comparability": false,
    "whether_difference_can_explain_polarity": true,
    "prompt_guidance": "Extract only when supported by the supplied local evidence."
  },
  "factor_overrides": {
    "species": {
      "aliases": ["organism"],
      "criticality": "critical",
      "normalization_policy": "resolver_acceptance_required",
      "controlled_normalizations": {"human": "Homo sapiens", "mouse": "Mus musculus", "rat": "Rattus norvegicus"},
      "whether_difference_can_block_comparability": true
    },
    "intervention": {"allowed_local_inference_rules": ["compose_intervention_target_and_type"]},
    "treatment": {"allowed_local_inference_rules": ["compose_intervention_target_and_type"]},
    "knockout_or_overexpression": {"allowed_local_inference_rules": ["compose_intervention_target_and_type"]},
    "comparator": {
      "allowed_local_inference_rules": ["project_comparator_control_surface"],
      "controlled_normalizations": {"control": "control", "vehicle": "vehicle", "untreated": "untreated", "mock": "mock", "non targeting sirna": "non-targeting_control"}
    },
    "placebo_or_standard_care": {
      "allowed_local_inference_rules": ["project_comparator_control_surface"],
      "controlled_normalizations": {"control": "control", "vehicle": "vehicle", "untreated": "untreated", "mock": "mock", "non targeting sirna": "non-targeting_control"}
    },
    "experimental_design": {"allowed_local_inference_rules": ["compose_experimental_design_intervention_and_comparator"]},
    "study_design": {"allowed_local_inference_rules": ["compose_experimental_design_intervention_and_comparator"]},
    "in_vivo_in_vitro_ex_vivo": {
      "allowed_local_inference_rules": [],
      "controlled_normalizations": {"in vitro": "in_vitro", "in vivo": "in_vivo", "ex vivo": "ex_vivo"}
    },
    "dose": {"value_type": "quantity", "units": ["M", "mM", "uM", "nM", "mg", "mg/kg"], "criticality": "conditional"},
    "duration": {"value_type": "duration", "units": ["s", "min", "h", "day", "week"]},
    "reaction_time": {"value_type": "duration", "units": ["s", "min", "h", "day"]},
    "follow_up": {"value_type": "duration", "units": ["day", "week", "month", "year"]},
    "temperature": {"value_type": "quantity", "units": ["K", "C", "°C"], "whether_difference_can_block_comparability": true},
    "pressure": {"value_type": "quantity", "units": ["Pa", "kPa", "bar", "atm"], "whether_difference_can_block_comparability": true},
    "concentration": {"value_type": "quantity", "units": ["M", "mM", "uM", "nM", "mol/L"]},
    "particle_size": {"value_type": "quantity", "units": ["nm", "um", "mm"]},
    "film_thickness": {"value_type": "quantity", "units": ["nm", "um", "mm"]},
    "loading": {"value_type": "quantity", "units": ["wt%", "mol%", "%"]},
    "flow_rate": {"value_type": "quantity", "units": ["mL/min", "L/min"]},
    "space_velocity": {"value_type": "quantity", "units": ["h-1", "mL g-1 h-1"]},
    "sample_size": {"value_type": "integer"},
    "yield": {"value_type": "quantity", "units": ["%"]},
    "selectivity": {"value_type": "quantity", "units": ["%"]},
    "conversion": {"value_type": "quantity", "units": ["%"]},
    "observed_outcome": {"evidence_requirements": "results_or_observation_anchor_required", "whether_difference_can_block_comparability": false}
  }
