    },
    "project_comparator_control_surface": {
      "factor_ids": ["comparator", "placebo_or_standard_care"],
      "components": [
        {"chain_node_id": "comparator_or_control", "field_path": "control_arm_raw"}
      ]
    },
    "compose_experimental_design_intervention_and_comparator": {
      "factor_ids": ["experimental_design", "study_design"],
