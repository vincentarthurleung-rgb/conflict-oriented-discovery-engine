      "critical": ["composition", "phase", "testing_configuration"]
    },
    "catalysis": {
      "display_name": "Catalysis",
      "factors": ["catalyst_composition", "support", "loading", "active_phase", "particle_size", "pretreatment", "activation", "feed_composition", "flow_rate", "space_velocity", "temperature", "pressure", "atmosphere", "conversion", "yield", "selectivity", "stability", "deactivation", "regeneration", "reactor_configuration", "measurement_configuration"],
