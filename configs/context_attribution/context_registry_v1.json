{
  "registry_version": "context_factor_registry_v1",
  "normalization_registry_version": "context_normalization_policy_v1",
  "profiles": {
    "generic": {
      "display_name": "Generic experimental context",
      "factors": [
        "experimental_system", "research_object", "intervention", "comparator",
        "temporal_condition", "environmental_condition", "measurement_endpoint",
        "measurement_method", "observed_outcome", "experimental_design",
        "sample_information", "preparation", "preprocessing", "missing_information"
      ]
    },
    "biomedical": {
      "display_name": "Biomedical",
      "factors": [
        "species", "strain", "sex", "age", "genotype", "knockout_or_overexpression",
        "tissue", "organ", "cell_type", "cell_line", "disease", "phenotype",
        "developmental_stage", "in_vivo_in_vitro_ex_vivo", "treatment", "dose",
        "route", "duration", "intervention_sequence", "assay", "normalization",
        "biological_endpoint"
      ],
      "critical": ["species", "experimental_system", "biological_endpoint"]
    },
    "clinical": {
      "display_name": "Clinical",
      "factors": [
        "population", "diagnosis", "disease_stage", "inclusion_criteria",
        "exclusion_criteria", "age_distribution", "sex_distribution", "ethnicity",
        "treatment_regimen", "line_of_therapy", "dose", "frequency",
        "combination_therapy", "comparator", "placebo_or_standard_care",
        "endpoint_definition", "follow_up", "subgroup", "sample_size", "study_design"
      ],
      "critical": ["population", "diagnosis", "endpoint_definition", "study_design"]
    },
    "chemistry": {
      "display_name": "Chemistry",
      "factors": [
        "reactants", "reagents", "stoichiometry", "catalyst", "ligand", "additive",
        "solvent", "concentration", "temperature", "pressure", "atmosphere",
        "reaction_time", "addition_order", "workup", "purification", "yield",
        "selectivity", "conversion", "analytical_method"
      ],
      "critical": ["reactants", "temperature", "measurement_method"]
    },
    "materials": {
      "display_name": "Materials",
      "factors": [
        "composition", "phase", "crystal_structure", "morphology", "particle_size",
        "defects", "substrate", "film_thickness", "synthesis_route", "deposition_route",
        "annealing", "calcination", "pretreatment", "temperature", "pressure",
        "atmosphere", "humidity", "testing_configuration", "mechanical_endpoint",
        "electrical_endpoint", "optical_endpoint", "thermal_endpoint"
      ],
      "critical": ["composition", "phase", "testing_configuration"]
    },
    "catalysis": {
      "display_name": "Catalysis",
      "factors": [
        "catalyst_composition", "support", "loading", "active_phase", "particle_size",
        "pretreatment", "activation", "feed_composition", "flow_rate", "space_velocity",
        "temperature", "pressure", "atmosphere", "conversion", "yield", "selectivity",
        "stability", "deactivation", "regeneration", "reactor_configuration",
        "measurement_configuration"
      ],
      "critical": ["catalyst_composition", "feed_composition", "reactor_configuration"]
    }
  },
  "factor_defaults": {
    "aliases": [],
    "value_type": "string",
    "units": [],
    "criticality": "optional",
    "applicability": "profile_defined",
    "comparison_policy": "semantic_same_equivalent_different_or_missing",
    "normalization_policy": "preserve_raw_and_propose_candidate_only",
    "evidence_requirements": "one_or_more_local_anchor_ids_for_non_unknown",
    "whether_difference_can_block_comparability": false,
    "whether_difference_can_explain_polarity": true,
    "prompt_guidance": "Extract only when supported by the supplied local evidence."
  },
  "factor_overrides": {
    "species": {
      "aliases": ["organism"],
      "criticality": "critical",
      "normalization_policy": "resolver_acceptance_required",
      "whether_difference_can_block_comparability": true
    },
    "dose": {"value_type": "quantity", "units": ["M", "mM", "uM", "nM", "mg", "mg/kg"], "criticality": "conditional"},
    "duration": {"value_type": "duration", "units": ["s", "min", "h", "day", "week"]},
    "reaction_time": {"value_type": "duration", "units": ["s", "min", "h", "day"]},
    "follow_up": {"value_type": "duration", "units": ["day", "week", "month", "year"]},
    "temperature": {"value_type": "quantity", "units": ["K", "C", "°C"], "whether_difference_can_block_comparability": true},
    "pressure": {"value_type": "quantity", "units": ["Pa", "kPa", "bar", "atm"], "whether_difference_can_block_comparability": true},
    "concentration": {"value_type": "quantity", "units": ["M", "mM", "uM", "nM", "mol/L"]},
    "particle_size": {"value_type": "quantity", "units": ["nm", "um", "mm"]},
    "film_thickness": {"value_type": "quantity", "units": ["nm", "um", "mm"]},
    "loading": {"value_type": "quantity", "units": ["wt%", "mol%", "%"]},
    "flow_rate": {"value_type": "quantity", "units": ["mL/min", "L/min"]},
    "space_velocity": {"value_type": "quantity", "units": ["h-1", "mL g-1 h-1"]},
    "sample_size": {"value_type": "integer"},
    "yield": {"value_type": "quantity", "units": ["%"]},
    "selectivity": {"value_type": "quantity", "units": ["%"]},
    "conversion": {"value_type": "quantity", "units": ["%"]},
    "observed_outcome": {
      "evidence_requirements": "results_or_observation_anchor_required",
      "whether_difference_can_block_comparability": false
    }
  }
}
